<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarDetails"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextAppearance="@style/TextAppearance.AppCompat.Widget.ActionBar.Title.Inverse"
            app:navigationIcon="@android:drawable/ic_menu_revert" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="20dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDetId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRJ-000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:chipBackgroundColor="#E1E2E8"
                    app:chipCornerRadius="16dp"
                    app:chipMinHeight="24dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDetStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:chipCornerRadius="16dp"
                    app:chipMinHeight="24dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvDetName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Skyline Corporate Hub"
                    android:textColor="@color/on_surface"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#F0F0F0"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CODE: "
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/outline"/>

                    <TextView
                        android:id="@+id/tvProjectPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A1B2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textColor="@color/primary"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#F5F5F5"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="20dp"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL BUDGET"
                            android:textSize="10sp"
                            android:textColor="@color/outline"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvDetBudget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$248,500.00"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#D1D1D1"
                        android:layout_marginHorizontal="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PROJECT MANAGER"
                            android:textSize="10sp"
                            android:textColor="@color/outline"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvDetManager"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alex Strathmore"
                            android:textSize="16sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/primary_dark"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/lblFunds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FUNDS UTILIZED"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#A0C9CB"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tvDetSpent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$182,420.50"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_primary_dark"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/lblFunds"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tvDetProgressPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="73%"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_primary_dark"
                        app:layout_constraintBottom_toBottomOf="@id/tvDetSpent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <ProgressBar
                        android:id="@+id/pbDetProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp"
                        android:progressDrawable="@drawable/bg_progress_bar"
                        android:max="100"
                        app:layout_constraintTop_toBottomOf="@id/tvDetSpent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Ledger"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"/>

<!--                <TextView-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="VIEW ALL"-->
<!--                    android:textSize="12sp"-->
<!--                    android:textStyle="bold"-->
<!--                    android:textColor="@color/primary"/>-->
            </LinearLayout>

            <TextView
                android:id="@+id/tvNoExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No expenses recorded yet."
                android:textAlignment="center"
                android:textColor="@color/outline"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:text="NEW EXPENSE"
        app:icon="@android:drawable/ic_input_add"
        android:textColor="@color/on_primary_fixed"
        app:iconTint="@color/on_primary_fixed"
        android:backgroundTint="@color/primary_fixed"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>